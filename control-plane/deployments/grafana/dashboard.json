{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""}
  ],
  "annotations": {"list": []},
  "description": "Grid Computing Control Plane Metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "Active Workers",
      "id": 1,
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "expr": "grid_workers_active_total",
          "legendFormat": "Active Workers"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "green", "value": 5}
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Queued Tasks",
      "id": 2,
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "grid_tasks_queued_total", "legendFormat": "Queued"}
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 50},
              {"color": "red", "value": 200}
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Running Tasks",
      "id": 3,
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "grid_tasks_running_total", "legendFormat": "Running"}
      ]
    },
    {
      "type": "stat",
      "title": "Tasks Completed (24h)",
      "id": 4,
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "increase(grid_tasks_completed_total[24h])", "legendFormat": "Completed"}
      ]
    },
    {
      "type": "stat",
      "title": "Assignment P99 Latency",
      "id": 5,
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(grid_task_assignment_duration_seconds_bucket[5m]))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 30},
              {"color": "red", "value": 60}
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Security Events (1h)",
      "id": 6,
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "increase(grid_security_events_total[1h])", "legendFormat": "Events"}
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Task Throughput",
      "id": 7,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "rate(grid_tasks_completed_total[5m])", "legendFormat": "Completed/s"},
        {"expr": "rate(grid_tasks_failed_total[5m])", "legendFormat": "Failed/s"},
        {"expr": "rate(grid_tasks_submitted_total[5m])", "legendFormat": "Submitted/s"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "ops"}
      }
    },
    {
      "type": "timeseries",
      "title": "Task Assignment Latency",
      "id": 8,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(grid_task_assignment_duration_seconds_bucket[5m]))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(grid_task_assignment_duration_seconds_bucket[5m]))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(grid_task_assignment_duration_seconds_bucket[5m]))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"lineWidth": 2}
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Worker States",
      "id": 9,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "grid_workers_by_state{state='idle'}", "legendFormat": "Idle"},
        {"expr": "grid_workers_by_state{state='busy'}", "legendFormat": "Busy"},
        {"expr": "grid_workers_by_state{state='paused'}", "legendFormat": "Paused"},
        {"expr": "grid_workers_by_state{state='offline'}", "legendFormat": "Offline"}
      ]
    },
    {
      "type": "timeseries",
      "title": "API Request Rate",
      "id": 10,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "targets": [
        {"expr": "rate(http_requests_total[5m])", "legendFormat": "{{method}} {{path}}"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps"}
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["grid-computing"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Grid Computing Control Plane",
  "uid": "grid-control-plane-v1",
  "version": 1
}
